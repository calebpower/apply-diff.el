# =============================================================================
# apply-diff .gitignore
# Covers Emacs build artifacts plus common OS and editor cruft.
# =============================================================================

# -----------------------------------------------------------------------------
# Emacs / Elisp
# -----------------------------------------------------------------------------
*.elc
*.eln
eln-cache/
/elpa/
/elpa-mirror/
.elc/
auto-save-list/
tramp
.tramp_history
\#*\#
.\#*
*~
.org-id-locations
*_archive
*.rel
flycheck_*.el
.projectile
.dir-locals-2.el

# Package build / dev tooling output
/dist/
/.cask/
.cask/
.eldev/
/.eldev/
.eask/
/.eask/
*-autoloads.el
*-pkg.el
/.package-build/
/server/

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.stackdump
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# FreeBSD / BSD / generic Unix
# -----------------------------------------------------------------------------
*.core
core
core.*
.sujournal
.recover

# -----------------------------------------------------------------------------
# Vim
# -----------------------------------------------------------------------------
[._]*.s[a-v][a-z]
!*.svg
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
*.un~
tags
[._]*.un~

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
.ionide/
*.vsix
.vscode-test/

# -----------------------------------------------------------------------------
# Other editors / IDEs
# -----------------------------------------------------------------------------
# JetBrains
.idea/
*.iml
*.iws
# Sublime Text
*.sublime-workspace
*.sublime-project
# Kate
*.kate-swp
.swp.*
# nano
*.save
# TextMate
*.tmproj
*.tmproject
tmtags
# Eclipse
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.log
*.bak
*.tmp
*.orig
